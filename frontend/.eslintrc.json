{
    "root":  true,
    "rules":  {
                  "no-useless-escape":  "error",
                  "react/no-unescaped-entities":  "off"
              },
    "extends":  [
                    "next",
                    "next/core-web-vitals"
                ],
    "overrides":  [
                      {
                          "files":  [
                                        "src/services/**/*.ts",
                                        "src/app/**/route.ts",
                                        "src/app/**/actions.ts"
                                    ],
                          "rules":  {
                                        "no-restricted-imports":  [
                                                                      "error",
                                                                      {
                                                                          "paths":  [
                                                                                        {
                                                                                            "name":  "@/lib/supabase",
                                                                                            "message":  "Do not import the barrel. Use \u0027@/lib/supabase/browser\u0027 (client) or \u0027@/lib/supabase/server\u0027 (server)."
                                                                                        }
                                                                                    ],
                                                                          "patterns":  [
                                                                                           {
                                                                                               "group":  [
                                                                                                             "@/hooks/*",
                                                                                                             "@/contexts/*",
                                                                                                             "@/components/*"
                                                                                                         ],
                                                                                               "message":  "Server code must not import client code"
                                                                                           }
                                                                                       ]
                                                                      }
                                                                  ]
                                    }
                      }
                  ]
}
