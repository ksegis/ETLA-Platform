{
  "root": true,
  "rules": {
    "no-useless-escape": "error"
  },
  "extends": ["next", "next/core-web-vitals"],
  "overrides": [
    {
      "files": ["src/services/**/*.ts", "src/app/**/route.ts", "src/app/**/actions.ts"],
      "rules": {
        "no-restricted-imports": ["error", {
          "paths": [{
            "name": "@/lib/supabase",
            "message": "Do not import the barrel. Use '@/lib/supabase/browser' (client) or '@/lib/supabase/server' (server)."
          }],
          "patterns": [
            {"group": ["@/hooks/*", "@/contexts/*", "@/components/*"], "message": "Server code must not import client code"}
          ]
        }]
      }
    }
  ]
}

