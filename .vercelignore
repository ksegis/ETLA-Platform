# Ignore build output directories
.next/
build/
dist/

# Ignore dependency directories
node_modules/

# Ignore environment variables and sensitive files
.env
.env.local
.env.development.local
.env.production.local
.env.*
*.env
*.pem
*.key
*.crt
private-keys/

# Ignore editor/IDE specific files and configurations
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ignore Git specific files and directories
.git/
.gitignore
.gitattributes
.gitmodules

# Ignore test files and directories
*.test.js
*.test.jsx
*.test.ts
*.test.tsx
*.spec.js
*.spec.jsx
*.spec.ts
*.spec.tsx
__tests__/
coverage/

# Ignore documentation and markdown files (unless they are part of your app)
*.md
*.mdx

# Ignore temporary files and logs
*.log
*.tmp
tmp/

# Ignore configuration files not needed at runtime
vercel.json
next.config.js
tsconfig.json
jsconfig.json
.eslintrc.json
.prettierrc.json
.prettierignore
.npmrc
.yarnrc
.pnpmrc

# Ignore husky configuration (if not needed for deployment runtime)
.husky/

# Ignore any other large or sensitive files not needed for the final build
public/uploads/
src/data/

# Example: If you have a specific folder for local development assets only
local-assets/

# Example: If you have a specific folder for design files
design/

# Example: If you have a specific folder for database migrations
database/migrations/
